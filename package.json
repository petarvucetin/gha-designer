{
  "name": "github-actions-designer",
  "private": true,
  "version": "0.1.0",
  "description": "Visual designer and local runner for GitHub Actions workflows",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/petarvucetin/gha-designer.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "server": "tsx watch server/index.ts",
    "dev:all": "concurrently -n web,runner -c blue,green \"npm run dev\" \"npm run server\"",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@tauri-apps/plugin-opener": "^2",
    "@xyflow/react": "^12.3.0",
    "highlight.js": "^11.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
