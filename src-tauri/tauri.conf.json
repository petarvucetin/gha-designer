{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "gha-designer",
  "version": "0.1.0",
  "identifier": "com.station5.gha-designer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build:sidecar && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GitHub Actions Designer",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/gha-runner", "binaries/act"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
